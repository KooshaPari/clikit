# Example environment configuration for Cmdra.
# Copy this file to `.env` and uncomment the variables you need.

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
# DEBUG=false
# LOG_LEVEL=info

# ------------------------------------------------------------------------------
# CLI Configuration
# ------------------------------------------------------------------------------
# DEFAULT_FORMAT=json
# COLOR_OUTPUT=true
# INTERACTIVE_MODE=true

# ------------------------------------------------------------------------------
# Plugin Configuration
# ------------------------------------------------------------------------------
# PLUGIN_DIR=./plugins
# TRUSTED_PLUGINS=./trusted-plugins.json
